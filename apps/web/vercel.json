{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @betaversionio/shared build && pnpm --filter @betaversionio/web build",
  "outputDirectory": ".next",
  "ignoreCommand": "[ -z \"$VERCEL_GIT_PREVIOUS_SHA\" ] && exit 1 || git diff --quiet $VERCEL_GIT_PREVIOUS_SHA HEAD -- . ../../packages/shared/"
}
