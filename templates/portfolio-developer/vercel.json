{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @betaversionio/portfolio-sdk build && pnpm --filter @betaversionio/template-developer build",
  "outputDirectory": ".next",
  "ignoreCommand": "[ -z \"$VERCEL_GIT_PREVIOUS_SHA\" ] && exit 1 || git diff --quiet $VERCEL_GIT_PREVIOUS_SHA HEAD -- . ../../packages/portfolio-sdk/"
}
