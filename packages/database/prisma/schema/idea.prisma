// ─── Enums ────────────────────────────────────────────────────────────────────

enum IdeaStage {
  CONCEPT
  PLANNING
  SEEKING_TEAM
  IN_PROGRESS
  LAUNCHED
}

enum Commitment {
  FULL_TIME
  PART_TIME
  FLEXIBLE
  ONE_TIME
}

enum Compensation {
  PAID
  EQUITY
  VOLUNTEER
  NEGOTIABLE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Idea {
  id                 String    @id @default(cuid())
  authorId           String
  title              String
  description        String    @db.Text
  stage              IdeaStage @default(CONCEPT)
  techStack          String[]
  votesCount         Int       @default(0)
  isOpen             Boolean   @default(true)
  convertedProjectId String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  // Relations
  author           User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  roles            IdeaRole[]
  applications     IdeaApplication[]
  votes            IdeaVote[]
  convertedProject Project?          @relation(fields: [convertedProjectId], references: [id], onDelete: SetNull)

  @@map("ideas")
}

model IdeaRole {
  id           String       @id @default(cuid())
  ideaId       String
  title        String
  description  String?      @db.Text
  commitment   Commitment
  compensation Compensation
  isFilled     Boolean      @default(false)
  createdAt    DateTime     @default(now())

  // Relations
  idea         Idea              @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  applications IdeaApplication[]

  @@map("idea_roles")
}

model IdeaApplication {
  id           String            @id @default(cuid())
  ideaId       String
  userId       String
  roleId       String
  message      String            @db.Text
  portfolioUrl String?
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  idea Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role IdeaRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId, roleId])
  @@map("idea_applications")
}

model IdeaVote {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  createdAt DateTime @default(now())

  // Relations
  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
  @@map("idea_votes")
}
