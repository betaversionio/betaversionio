{
  "name": "@betaversionio/portfolio-sdk",
  "version": "0.1.0",
  "description": "SDK for fetching BetaVersion.io portfolio data. Framework-agnostic — works with Next.js, Remix, Astro, Vite, or any environment with global fetch.",
  "author": "BetaVersion.IO <hello@betaversion.io> (https://betaversion.io)",
  "license": "MIT",
  "homepage": "https://github.com/betaversionio/betaversionio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betaversionio/betaversionio.git",
    "directory": "packages/portfolio-sdk"
  },
  "bugs": {
    "url": "https://github.com/betaversionio/betaversionio/issues"
  },
  "keywords": [
    "betaversion",
    "portfolio",
    "developer",
    "sdk",
    "api-client"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@betaversionio/typescript-config": "workspace:*",
    "@types/node": "^25.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
