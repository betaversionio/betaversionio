{
  "name": "@betaversionio/portfolio-sdk",
  "version": "0.1.0",
  "description": "SDK for fetching BetaVersion.io portfolio data",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@betaversionio/typescript-config": "workspace:*",
    "@types/node": "^25.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
