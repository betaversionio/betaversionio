# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/betaversionio?schema=public"

# Auth
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRATION="7d"
JWT_REFRESH_EXPIRATION="15d"

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitHub App (for repo sync — create at GitHub > Settings > Developer settings > GitHub Apps)
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY_PATH=""
GITHUB_APP_PRIVATE_KEY=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="betaversionio"
R2_PUBLIC_URL=""

# LaTeX (for resume PDF generation)
PDFLATEX_PATH="pdflatex"

# SMTP (email)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BetaVersion.IO <noreply@betaversion.io>"

# App
PORT=4000
NODE_ENV="development"
