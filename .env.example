# GitHub App (for repo sync — create at GitHub > Settings > Developer settings > GitHub Apps)
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY_PATH=""
GITHUB_APP_PRIVATE_KEY=""
NEXT_PUBLIC_GITHUB_APP_SLUG=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="betaversionio"
R2_PUBLIC_URL=""

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# SMTP (email)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
