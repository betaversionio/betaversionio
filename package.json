{
  "name": "betaversionio",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter @betaversionio/api",
    "dev:web": "turbo dev --filter @betaversionio/web",
    "dev:template-nextjs": "turbo dev --filter @betaversionio/template-nextjs",
    "dev:template-vite": "turbo dev --filter @betaversionio/template-vite",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @betaversionio/database db:generate",
    "db:push": "pnpm --filter @betaversionio/database db:push",
    "db:migrate": "pnpm --filter @betaversionio/database db:migrate",
    "db:seed": "pnpm --filter @betaversionio/database db:seed",
    "db:studio": "pnpm --filter @betaversionio/database db:studio",
    "clean": "turbo clean && rm -rf node_modules",
    "publish:portfolio-sdk": "pnpm --filter @betaversionio/portfolio-sdk build && pnpm --filter @betaversionio/portfolio-sdk publish --access public"
  },
  "devDependencies": {
    "turbo": "^2.8.14",
    "prettier": "^3.8.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "esbuild",
      "@nestjs/core",
      "sharp"
    ]
  }
}
